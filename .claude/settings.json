{
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git fetch*)",
      "Bash(git merge*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git branch*)",
      "Bash(git worktree*)",
      "Bash(git checkout*)",
      "Bash(git check-ignore*)",
      "Bash(git -C * add *)",
      "Bash(git -C * commit*)",
      "Bash(git -C * push*)",
      "Bash(git -C * fetch*)",
      "Bash(git -C * merge*)",
      "Bash(git -C * worktree*)",
      "Bash(gh auth*)",
      "Bash(gh repo*)",
      "Bash(gh issue*)",
      "Bash(gh pr*)",
      "Bash(pytest*)",
      "Bash(pip *)",
      "Bash(python*)",
      "Bash(python3*)",
      "Bash(pbrew *)",
      "Bash(.venv/bin/*)",
      "Bash(/home/patric/apache/projekte/pbrew/.worktrees/*/.venv/bin/*)",
      "WebSearch"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".venv/bin/pytest --no-header -q 2>&1 | tail -8"
          }
        ]
      }
    ]
  }
}
