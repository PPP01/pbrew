{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(pytest*)",
      "Bash(pip *)",
      "Bash(python*)",
      "Bash(python3*)",
      "Bash(pbrew *)",
      "Bash(.venv/bin/*)",
      "Bash(/home/patric/apache/projekte/pbrew/.venv/bin/*)",
      "Bash(/home/patric/apache/projekte/pbrew/.worktrees/*/.venv/bin/*)",
      "Bash(PYTHONPATH=*)",
      "WebSearch",
      "Read(//home/patric/.pbrew/**)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".venv/bin/pytest --no-header -q 2>&1 | tail -8"
          }
        ]
      }
    ]
  }
}
